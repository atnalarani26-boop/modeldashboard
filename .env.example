# ============================================================
# Environment Variables — Sentiment Intelligence Center
# Copy this to .env and fill in your values
# ============================================================

# Google Service Account credentials (base64-encoded JSON)
# Run: base64 -w 0 credentials.json  (Linux/Mac)
# Run: certutil -encode credentials.json tmp.b64 && type tmp.b64  (Windows)
GOOGLE_CREDENTIALS_BASE64=

# Google Cloud Storage bucket for model persistence
GCS_BUCKET_NAME=sentiment-model-store

# Admin password for the Streamlit dashboard
ADMIN_PASSWORD=admin123

# Internal API URL (don't change for Cloud Run)
API_URL=http://localhost:5000
